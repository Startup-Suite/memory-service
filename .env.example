# Embedding backend: "local" (in-process GPU) or "http" (remote TEI)
MEMORY_EMBEDDING_BACKEND=local
MEMORY_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Only used when BACKEND=local
MEMORY_EMBEDDING_DEVICE=cuda

# Only used when BACKEND=http — point at a Text Embeddings Inference (or OpenAI-compatible) server
# MEMORY_EMBEDDING_URL=http://tei-host:8088

# Postgres (pgvector). Point at the bundled container, an existing pgvector DB, or a shared
# postgres with the `vector` extension installed.
MEMORY_DATABASE_URL=postgresql://memory:memory@localhost:5432/memory

# Optional API key for authentication
# MEMORY_API_KEY=your-secret-key

# Server
MEMORY_HOST=0.0.0.0
MEMORY_PORT=8100
